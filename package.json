{
  "name": "icojs",
  "version": "0.20.2",
  "description": "parse ico file",
  "keywords": [
    "ico",
    "parse"
  ],
  "homepage": "https://egy186.github.io/icojs",
  "bugs": {
    "url": "https://github.com/egy186/icojs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/egy186/icojs.git"
  },
  "license": "MIT",
  "author": "egy186",
  "type": "module",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/node/index.js"
    },
    "./browser": {
      "types": "./types/index.d.ts",
      "default": "./src/browser/index.js"
    }
  },
  "browser": "./src/browser/index.js",
  "types": "./types/index.d.ts",
  "files": [
    "dist",
    "src",
    "!src/test-fixtures",
    "!src/**/*.test.js",
    "types"
  ],
  "scripts": {
    "build": "vite build",
    "clean": "rimraf coverage dist docs/index.html templates/api.md README.md",
    "predocs": "npm run jsdoc",
    "docs": "node scripts/docs.js",
    "jsdoc": "jsdoc2md --files \"src/**/*.js\" --heading-depth 3 --template templates/api.hbs > templates/api.md",
    "lint": "eslint",
    "test": "vitest run --coverage",
    "version": "npm run docs && git add docs/index.html README.md"
  },
  "dependencies": {
    "@jimp/bmp": "^0.22.12",
    "decode-ico": "^0.4.1",
    "file-type": "^21.3.4",
    "jpeg-js": "^0.4.4",
    "pngjs": "^7.0.0",
    "to-data-view": "^2.0.0"
  },
  "devDependencies": {
    "@egy186/eslint-config": "^4.4.3",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-istanbul": "^4.1.2",
    "bowser": "^2.14.1",
    "data-uri-to-buffer": "^8.0.0",
    "ejs": "^5.0.1",
    "eslint": "^9.39.4",
    "jsdoc-to-markdown": "^9.1.3",
    "jsonfile": "^6.2.0",
    "marked": "^17.0.5",
    "pixelmatch": "^7.1.0",
    "rimraf": "^6.1.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.19.4"
  }
}
