{
  "name": "icojs",
  "version": "0.20.2",
  "description": "parse ico file",
  "keywords": [
    "ico",
    "parse"
  ],
  "homepage": "https://egy186.github.io/icojs",
  "bugs": {
    "url": "https://github.com/egy186/icojs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/egy186/icojs.git"
  },
  "license": "MIT",
  "author": "egy186",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "default": "./dist/node/index.js"
    },
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "default": "./dist/browser/index.js"
    }
  },
  "browser": "./dist/browser/index.js",
  "types": "./dist/node/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.test.d.ts*",
    "!dist/**/*.test.js*",
    "!dist/test-fixtures",
    "src",
    "!src/**/*.test.ts",
    "!src/test-fixtures"
  ],
  "scripts": {
    "build": "npm run build:ts && npm run build:umd",
    "build:ts": "tsc",
    "build:umd": "vite build",
    "clean": "rimraf coverage dist docs templates/api.md README.md",
    "predocs": "npm run jsdoc",
    "docs": "node scripts/docs.js",
    "prejsdoc": "npm run build",
    "jsdoc": "jsdoc2md --files \"dist/**/*.js\" --heading-depth 3 --template templates/api.hbs > templates/api.md",
    "lint": "eslint",
    "test": "vitest run --coverage",
    "version": "npm run docs && git add README.md"
  },
  "dependencies": {
    "@jimp/bmp": "^0.22.12",
    "decode-ico": "^0.4.1",
    "file-type": "^21.3.4",
    "jpeg-js": "^0.4.4",
    "pngjs": "^7.0.0",
    "to-data-view": "^2.0.0"
  },
  "devDependencies": {
    "@egy186/eslint-config": "^4.4.3",
    "@types/node": "^25.5.0",
    "@types/pngjs": "^6.0.5",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-istanbul": "^4.1.2",
    "@vitest/eslint-plugin": "^1.6.14",
    "bowser": "^2.14.1",
    "data-uri-to-buffer": "^8.0.0",
    "ejs": "^5.0.1",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "jsdoc-to-markdown": "^9.1.3",
    "jsonfile": "^6.2.0",
    "marked": "^17.0.5",
    "pixelmatch": "^7.1.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.19.4"
  }
}
