{
  "name": "icojs",
  "version": "1.0.0",
  "description": "Decode and encode ICO files",
  "keywords": [
    "ico",
    "decode",
    "encode"
  ],
  "homepage": "https://egy186.github.io/icojs",
  "bugs": {
    "url": "https://github.com/egy186/icojs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/egy186/icojs.git"
  },
  "license": "MIT",
  "author": "egy186",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/browser/index.d.ts",
        "default": "./dist/browser/index.js"
      },
      "types": "./dist/node/index.d.ts",
      "default": "./dist/node/index.js"
    },
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "default": "./dist/browser/index.js"
    }
  },
  "browser": "./dist/browser/index.js",
  "types": "./dist/node/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.test.d.ts*",
    "!dist/**/*.test.js*",
    "!dist/test-fixtures",
    "src",
    "!src/**/*.test.ts",
    "!src/test-fixtures"
  ],
  "scripts": {
    "build": "npm run build:ts && npm run build:umd",
    "build:ts": "tsc",
    "build:umd": "vite build",
    "clean": "node -e \"['coverage','dist','docs'].forEach(p=>fs.rmSync(p,{force:true,recursive:true}))\"",
    "predocs": "npm run build:umd",
    "docs": "typedoc",
    "postdocs": "node -e \"fs.cpSync('assets','docs',{recursive:true})\"",
    "lint": "eslint",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "bmp-ts": "^1.0.9",
    "decode-ico": "^0.4.1",
    "file-type": "^22.0.1",
    "jpeg-js": "^0.4.4",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@egy186/eslint-config": "^4.6.0",
    "@types/node": "^25.7.0",
    "@types/pngjs": "^6.0.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-istanbul": "^4.1.5",
    "@vitest/eslint-plugin": "^1.6.17",
    "bowser": "^2.14.1",
    "data-uri-to-buffer": "^8.0.0",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "pixelmatch": "^7.2.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.22.2"
  }
}
